# AuraOps - Environment Variables Configuration

# --------------------------
# API ANALYZER CONFIGURATION
# --------------------------
# ACTIVE PROFILE: (options: openai, ollama, anthropic)
AURAOPS_ANALYZER_PROFILE=openai

# OPENAI (Required if profile is openai)
# Use 'offline_dummy_key' if you just want to boot the system disconnected
OPENAI_API_KEY=offline_dummy_key

# OLLAMA (Required if profile is ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ANTHROPIC (Required if profile is anthropic)
ANTHROPIC_API_KEY=
